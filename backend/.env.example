# ── Sunucu ──────────────────────────────────────────
PORT=5000
NODE_ENV=development          # production | development

# ── Veritabanı ──────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/mekan_db

# ── JWT ─────────────────────────────────────────────
# En az 32 karakterlik rastgele string kullanın:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=BURAYA_GERCEK_SECRET_YAZIN
JWT_EXPIRES_IN=7d

# ── Google Gemini ────────────────────────────────────
GEMINI_API_KEY=BURAYA_GEMINI_API_KEY_YAZIN

# ── İlk Admin (seed script için) ────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=BURAYA_GUCLU_SIFRE_YAZIN
